# Build configuration for the offline simplex-chat / simplexmq build environment.
# Sourced by prefetch.sh (online) and setup-offline.sh / build.sh (offline host).

# --- Source version -------------------------------------------------------------
# simplex-chat ref to build (branch, tag, or commit). simplexmq's version is pinned
# transitively by this ref's cabal.project.
SIMPLEX_CHAT_REF=stable
SIMPLEX_CHAT_REPO=https://github.com/simplex-chat/simplex-chat.git

# --- Toolchain base -------------------------------------------------------------
# simplex-chat upstream targets GHC 9.6.3, but haskell:9.6.3 is on EOL Debian buster
# (apt repos 404). 9.6.7-bullseye is the closest maintained image; the patch diff does
# not affect the build (deps pinned via cabal.project index-state). Pin by digest for
# reproducibility: HASKELL_IMAGE=haskell:9.6.7-bullseye@sha256:<digest>
HASKELL_IMAGE=haskell:9.6.7-bullseye

# --- Images ---------------------------------------------------------------------
# Internal cache-warming builder (NOT shipped; produced during prefetch).
SEED_IMAGE=simplex-offline-builder:seed
# Shipped build environment: toolchain + dev libs + warmed ~/.cabal cache, NO source.
TOOLCHAIN_IMAGE=simplex-offline-toolchain:latest
# Slim base for packaging the final binaries.
RUNTIME_BASE_IMAGE=simplex-offline-runtime-base:latest
# Final image produced on the offline host by build.sh.
OUTPUT_IMAGE=simplex-offline:latest

# --- Transfer artifacts (produced by prefetch.sh) -------------------------------
# docker save of TOOLCHAIN_IMAGE + RUNTIME_BASE_IMAGE.
IMAGES_BUNDLE=simplex-offline-images.tar.gz
# The source tree (source + vendor/ + rewritten cabal.project + dist-newstyle).
SRC_BUNDLE=simplex-chat-offline-src.tar.gz

# --- Host paths -----------------------------------------------------------------
# Where setup-offline.sh extracts the repos on the offline host (relative to this
# directory). simplex-chat and simplexmq are SEPARATE, independently-editable git repos;
# simplex-chat's cabal.project references the sibling as ../simplexmq.
SRC_DIR=simplex-chat
SIMPLEXMQ_DIR=simplexmq
# Paths the repos are mounted at inside the container. MUST stay fixed (and keep the
# sibling relationship simplex-chat <-> ../simplexmq): dist-newstyle was created with
# these paths online, so the offline build must reuse them for the cache to stay valid.
CONTAINER_SRC=/src/simplex-chat
CONTAINER_SIMPLEXMQ=/src/simplexmq
